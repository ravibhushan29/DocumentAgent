# DocAgent — copy to .env for local development (Section 21)
# Production: use AWS Secrets Manager + External Secrets Operator

# ── Application ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/docdb
PGBOUNCER_URL=

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=2
REDIS_CELERY_RESULT_DB=1

# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=doc.ingestion
KAFKA_TOPIC_RETRY=doc.ingestion.retry
KAFKA_TOPIC_DLQ=doc.ingestion.dlq
KAFKA_TOPIC_EVENTS=doc.events
KAFKA_CONSUMER_GROUP=ingestion-workers
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ── AWS ───────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=docagent-uploads-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AI / Embeddings ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o
EMBEDDING_BATCH_SIZE=100

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-256-bit-random-string-in-prod
JWT_EXPIRE_HOURS=24

# ── Observability ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=docagent-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
GLITCHTIP_DSN=
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# ── Upload limits ─────────────────────────────────────────────────────
MAX_FILE_BYTES=524288000
ALLOWED_FILE_TYPES=pdf,docx
